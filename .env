# ──────────────────────────────────────────────
# LedgerFlow — Environment Variables
# Copy this file to .env and adjust the values
# ──────────────────────────────────────────────

# Environment
ASPNETCORE_ENVIRONMENT=Development

# Ports (host-side)
API_PORT=5000
FRONTEND_PORT=4200
DB_PORT=5432
REDIS_PORT=6379

# PostgreSQL
POSTGRES_DB=ledgerflow
POSTGRES_USER=ledger
POSTGRES_PASSWORD=ledger_secret

# Redis
REDIS_PASSWORD=redis_secret

# JWT
JWT_SECRET=change-me-in-production-use-a-long-random-string-at-least-32-chars
JWT_ISSUER=ledgerflow
JWT_AUDIENCE=ledgerflow-client

# Frontend API URL (used at Angular build time)
API_URL=http://localhost:5000
